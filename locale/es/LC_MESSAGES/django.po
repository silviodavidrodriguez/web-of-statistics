msgid "Multivariate Regression"
msgstr "Regresión Multivariada"

#: .\home\templates\home\index.html:239
msgid ""
"Principal Component Regression (PCR) and Partial Least Squares Regression "
"(PLSR) with training, cross-validation and external validation."
msgstr ""
"Regresión por Componentes Principales (PCR) y Regresión por Mínimos "
"Cuadrados Parciales (PLSR) con entrenamiento, validación cruzada y "
"validación externa."

#: .\home\templates\home\index.html:247
#: .\home\templates\home\sidebar_clean.html:54
msgid "Classification"
msgstr "Clasificación"

#: .\home\templates\home\index.html:249
msgid ""
"LDA, QDA, PLS-DA, Logistic Regression, Naive Bayes, k-NN and Support Vector "
"Machines (SVM) with training, cross-validation and external validation."
msgstr ""
"LDA, QDA, PLS-DA, Regresión Logística, Naive Bayes, k-NN y Máquinas de "
"Vectores de Soporte (SVM) con entrenamiento, validación cruzada y validación "
"externa."

