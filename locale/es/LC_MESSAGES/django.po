msgid "Control Charts"
msgstr "Cartas de Control"

#: .\home\templates\home\index.html:212
msgid ""
"Shewhart charts, precontrol charts, EWMA and CUSUM tools for quality control."
msgstr ""
"Herramientas para control de calidad mediante gráficos de Shewhart, gráficos "
"de precontrol, EWMA y CUSUM."

#: .\home\templates\home\index.html:216
msgid "ANOVA & MANOVA"
msgstr "ANOVA y MANOVA"

#: .\home\templates\home\index.html:218
msgid ""
"One-way ANOVA, two-way ANOVA, randomized block ANOVA, MANOVA, post-hoc "
"comparisons, assumption checks, canonical discriminant analysis and "
"diagnostic plots."
msgstr ""
"ANOVA de un factor, ANOVA de dos factores, ANOVA en bloques aleatorizados, "
"MANOVA, comparaciones post hoc, verificación de supuestos, análisis "
"discriminante canónico y gráficos de diagnóstico."

